# .dockerignore for the commit-image build.
# Goal: bake in the FULL repo (including .git history — the grader uses it),
# dropping only local build artifacts and editor/OS cruft. Dev image, not minimal.

# ── Build outputs / local cruft ──────────────────────────────────────────────
# build.sh produces its outputs under /mayhem at build time; keep host artifacts out.
mayhem-build/
mayhem-tests/
mayhem-fuzz_libunwind*.o
mayhem-standalone_main.o
*.o
*.a
*.so
*.lo
*.la
.libs/
**/__pycache__/

# autotools-generated noise (regenerated by autoreconf inside the image)
autom4te.cache/

# ── Editor / OS noise ────────────────────────────────────────────────────────
.DS_Store
*.swp
*~
